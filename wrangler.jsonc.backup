{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "grystl-em",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "grystl-em","database_id": "c42849fd-fd49-4632-be0e-fd13f0005901",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "grystl-em-media","preview_bucket_name": "grystl-em-media",
		},
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "db51385cb04049c688b81f9a56f4a6de"
		}
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
